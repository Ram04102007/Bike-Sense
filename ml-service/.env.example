# BikeSense ML Service — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# ── SMTP Email (for OTP verification) ─────────────────────────
# Get a Gmail App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=BikeSense AI

# ── Optional overrides ─────────────────────────────────────────
# DATA_PATH=/path/to/custom/bike_data.csv
